# backend/.env.development.template
#
# Copy to .env.development:
#   cp backend/.env.development.template backend/.env.development
#
# Profil DEV LOCAL. Presupune docker compose porneste Postgres :5433 si Redis :6380
# (vezi docker-compose.dev.yml la root). Toate integrarile externe (Stripe, R2,
# email) sunt UNSET ca sa nu se "scape" emailuri reale / chei live.
#
# Override personal: .env.development.local (gitignored, prioritate mai mare).
# Cascade Medusa: .env.development.local > .env.local > .env.development > .env

# =====================================================
# DATABASE (docker compose dev cluster pe :5433)
# =====================================================
# Default: clona sanitizata din prod. Schimba la medusa_dev_fresh
# daca rulezi `make dev-seed-fresh` in loc de `make dev-clone`.
DATABASE_URL=postgres://medusa:medusa@127.0.0.1:5433/medusa_dev_clone

# =====================================================
# REDIS (docker compose dev cluster pe :6380)
# =====================================================
# Optional. Comenteaza linia daca vrei Medusa cu fallback in-memory
# (event-bus, cache, workflow-engine in-process).
REDIS_URL=redis://127.0.0.1:6380

# =====================================================
# CORS (storefront pe :8000, admin bundle pe :9000/app)
# =====================================================
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# =====================================================
# SECURITY (dev-only weak secrets - NICIODATA in prod)
# =====================================================
JWT_SECRET=dev-jwt-not-secret-change-me
COOKIE_SECRET=dev-cookie-not-secret-change-me

# =====================================================
# SITE BASE URL (folosit in email templates - links inapoi la storefront)
# =====================================================
SITE_BASE_URL=http://localhost:8000

# =====================================================
# EMAIL (DEZACTIVAT in dev)
# =====================================================
# Atat SMTP2GO_API_KEY cat si SMTP_HOST UNSET -> modulul notification-smtp2go
# NU se inregistreaza (vezi medusa-config.ts:80). Niciun email nu pleaca.
# Daca vrei mail testing local: pune SMTP_HOST=localhost si ruleaza mailpit.
# SMTP2GO_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
SMTP_FROM_TRANSACTIONAL=dev-comenzi@ardmag.local
SMTP_FROM_CONTACT=dev-contact@ardmag.local
SMTP_FROM_NOREPLY=dev-noreply@ardmag.local
SMTP_REPLY_TO=dev-office@ardmag.local

# =====================================================
# ADMIN RECIPIENTS (override-uri SILENT default-uri prod)
# =====================================================
# In prod ORDER_NOTIFY_CC=office@ardmag.ro si NOTIFICATION_BCC=dc@aibaza.ro
# sunt HARDCODED ca default. Set la "" explicit ca dev sa nu bcc-uiasca nimic real.
ORDER_NOTIFY_EMAIL=dev-comenzi@ardmag.local
ORDER_NOTIFY_CC=
NOTIFICATION_BCC=

# =====================================================
# STRIPE (TEST MODE - placeholder, ne-comenteaza si pune cheia ta sk_test_*)
# =====================================================
# Atat cheia secret cat si webhook-ul UNSET -> modulul Stripe NU se inregistreaza.
# Daca pui cheia: foloseste-o pe cea TEST din dashboard.stripe.com (mod test).
# Pune valori reale in .env.development.local (gitignored).
# STRIPE_API_KEY=<sk_test_... din dashboard.stripe.com mod test>
# STRIPE_WEBHOOK_SECRET=<whsec_... din stripe listen output>
# Nota: nu pune cheia reala AICI in template. Doar in .env.development.local sau .env.development

# =====================================================
# CLOUDFLARE R2 (DEZACTIVAT in dev)
# =====================================================
# Atat R2_ACCESS_KEY_ID cat si R2_SECRET_ACCESS_KEY UNSET -> file module foloseste
# fallback local. Upload-urile cad in backend/static/.
# NICIODATA nu pune cheile prod in .env.development.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# =====================================================
# FAN COURIER (DEZACTIVAT in dev)
# =====================================================
# Provider returneaza mock rates daca credentialele lipsesc.
# FAN_COURIER_USERNAME=
# FAN_COURIER_PASSWORD=
# FAN_COURIER_CLIENT_ID=
# FAN_COURIER_API_URL=https://api.fancourier.ro

# =====================================================
# ADMIN UI (Medusa admin pe :9000/app)
# =====================================================
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=backend-storefront
# DISABLE_MEDUSA_ADMIN=true  # uncomment ca sa porneasca backend fara admin SPA
