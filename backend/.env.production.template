# Railway — copiaza acest fisier in Railway Variables
# Valorile cu <...> trebuie completate

# Database (Railway Postgres - se seteaza automat daca folosesti Railway Postgres plugin)
DATABASE_URL=<postgresql://user:pass@host:5432/dbname>

# Redis (Railway Redis - se seteaza automat daca folosesti Railway Redis plugin)
REDIS_URL=<redis://user:pass@host:6379>

# Security
JWT_SECRET=<genereaza cu: openssl rand -hex 32>
COOKIE_SECRET=<genereaza cu: openssl rand -hex 32>

# CORS - storefront si admin
STORE_CORS=https://magazin.ardmag.com,https://ardmag.com
ADMIN_CORS=https://admin.ardmag.com,https://api.ardmag.com
AUTH_CORS=https://magazin.ardmag.com,https://ardmag.com,https://admin.ardmag.com,https://api.ardmag.com

# Stripe (keys de la Cristian)
STRIPE_API_KEY=<sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>

# SMTP2GO (SMTP relay - credentials existente)
SMTP2GO_USER=<smtp username>
SMTP2GO_PASSWORD=<smtp password>
SMTP_FROM=office@arcromdiamonds.ro

# Cloudflare R2 (imagini produse)
S3_FILE_URL=https://media.ardmag.com
S3_ACCESS_KEY_ID=<R2 Access Key ID>
S3_SECRET_ACCESS_KEY=<R2 Secret Access Key>
S3_BUCKET=ardmag-media
S3_REGION=auto
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Admin
MEDUSA_ADMIN_ONBOARDING_TYPE=false
__MEDUSA_ADMIN_ADDITIONAL_ALLOWED_HOSTS=admin.ardmag.com
