# Railway — copiaza acest fisier in Railway Variables
# Valorile cu <...> trebuie completate

# Database (Railway Postgres - se seteaza automat daca folosesti Railway Postgres plugin)
DATABASE_URL=<postgresql://user:pass@host:5432/dbname>

# Redis (Railway Redis - se seteaza automat daca folosesti Railway Redis plugin)
REDIS_URL=<redis://user:pass@host:6379>

# Security
JWT_SECRET=<genereaza cu: openssl rand -hex 32>
COOKIE_SECRET=<genereaza cu: openssl rand -hex 32>

# CORS - storefront si admin
STORE_CORS=https://ardmag.ro,https://www.ardmag.ro
ADMIN_CORS=https://admin.ardmag.ro,https://api.ardmag.ro
AUTH_CORS=https://ardmag.ro,https://www.ardmag.ro,https://admin.ardmag.ro,https://api.ardmag.ro

# Stripe (keys de la Cristian)
STRIPE_API_KEY=<sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>

# SMTP2GO
SMTP2GO_API_KEY=<api key din SMTP2GO dashboard>
# SMTP relay (fallback, nefolosit cand API key e setat)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USERNAME=<smtp username>
SMTP_PASSWORD=<smtp password>
# Adrese sender @ardmag.ro (autentificate DKIM/SPF in SMTP2GO)
SMTP_FROM_TRANSACTIONAL=comenzi@ardmag.ro
SMTP_FROM_CONTACT=contact@ardmag.ro
SMTP_FROM_NOREPLY=no-reply@ardmag.ro
SMTP_REPLY_TO=office@ardmag.ro
# Admin recipients
ORDER_NOTIFY_EMAIL=office@ardmag.ro
CONTACT_NOTIFY_EMAIL=office@ardmag.ro
# URL site pentru link-uri in emailuri
SITE_BASE_URL=https://ardmag.ro

# Cloudflare R2 (imagini produse)
S3_FILE_URL=https://media.ardmag.com
S3_ACCESS_KEY_ID=<R2 Access Key ID>
S3_SECRET_ACCESS_KEY=<R2 Secret Access Key>
S3_BUCKET=ardmag-media
S3_REGION=auto
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Admin
MEDUSA_ADMIN_ONBOARDING_TYPE=false
__MEDUSA_ADMIN_ADDITIONAL_ALLOWED_HOSTS=admin.ardmag.ro
