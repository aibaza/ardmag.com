# backend-storefront/.env.development.template
#
# Copy:
#   cp backend-storefront/.env.development.template backend-storefront/.env.development
#
# IMPORTANT - Vercel CLI poate suprascrie .env.local. Daca foloseste vercel CLI:
#   - sterge .env.local (sau muta-l in .env.development.local)
#   - .env.development e prioritate JOSA fata de .env.local
# Recomandat: nu rula `vercel env pull` pe storefront-ul dev local.

# =====================================================
# MEDUSA BACKEND (server-side - utilizat de RSC, middleware, server actions)
# =====================================================
MEDUSA_BACKEND_URL=http://localhost:9000

# =====================================================
# PUBLISHABLE API KEY (HARD-REQUIRED - storefront refuza sa porneasca fara)
# =====================================================
# check-env-variables.js face process.exit(1) daca lipseste.
# Genereaza-l:
#   make dev-seed-fresh       -> printeaza key-ul la final
#   sau: make dev-publishable-key  -> printeaza din DB curent
# Apoi paste valoarea AICI (sau in .env.development.local).
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_ME_AFTER_SEED

# =====================================================
# STOREFRONT BASE URL
# =====================================================
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# =====================================================
# DEFAULT REGION (Romania)
# =====================================================
NEXT_PUBLIC_DEFAULT_REGION=ro

# =====================================================
# STRIPE (TEST publishable key - optional; UNSET -> Stripe UI ascuns)
# =====================================================
# Trebuie sa potriveasca STRIPE_API_KEY din backend (sk_test_/pk_test_ pereche).
# NEXT_PUBLIC_STRIPE_KEY=<pk_test_... din dashboard.stripe.com mod test>

# =====================================================
# IMAGE DOMAINS (pentru next/image remote patterns)
# =====================================================
# Defaults functioneaza (api.ardmag.ro pentru imagini prod, R2 CDN, localhost).
NEXT_PUBLIC_R2_HOSTNAME=pub-28d7a4f80d924560ae8c2fe111240e4a.r2.dev
NEXT_PUBLIC_BACKEND_HOSTNAME=api.ardmag.ro

# =====================================================
# REVALIDATION (any random string pentru dev)
# =====================================================
REVALIDATE_SECRET=dev-revalidate-not-secret-change-me

# =====================================================
# CONTACT FORM SMTP (DEZACTIVAT in dev)
# =====================================================
# /api/contact returneaza 503 daca SMTP_HOST + SMTP2GO_API_KEY ambele UNSET.
# Acceptabil in dev.
# SMTP2GO_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_CONTACT=dev-contact@ardmag.local
# SMTP_FROM_NOREPLY=dev-noreply@ardmag.local
# SMTP_REPLY_TO=dev-office@ardmag.local
# CONTACT_NOTIFY_EMAIL=dev-comenzi@ardmag.local

# =====================================================
# ANALYTICS (NU activa in dev - pollueaza analytics prod)
# =====================================================
# UNSET -> GA4 si Pixel auto-dezactivate (componentele returneaza null).
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
